# Razorpay Keys — get these from your Razorpay Dashboard
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay Webhook Secret — set this in Razorpay Dashboard > Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Gmail credentials for sending invoices
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# Port (Render sets this automatically, leave as 4000 locally)
PORT=4000
